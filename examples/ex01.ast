@package ast;
@import java.lang.list;

Node
  Program[file:String]
  Subroutine[name:String,parameters:[]String,body:Statement]
  Statement[]
    Sequence[items:[]Statement]
    If[condition:Expression,decision:Statement,alternative:Statement]
  Expression[]
    Variable[name:String]
    NumberLiteral[value:double]
    Binary[operation:String,left:Expression,right:Expression]
